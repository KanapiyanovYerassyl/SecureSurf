{
  "manifest_version": 3,
  "name": "SecureSurf",
  "version": "1.0.0",
  "description": "Real-time phishing detection for emails and web browsing",
  "permissions": [
    "activeTab",
    "storage",
    "scripting"
  ],
  "host_permissions": [
    "https://safebrowsing.googleapis.com/*",
    "https://www.virustotal.com/*",
    "<all_urls>"
  ],
  "action": {
    "default_popup": "./popup.html",
    "default_icon": {
      "16": "./icons/icon16.png",
      "48": "./icons/icon48.png",
      "128": "./icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "./src/app.py"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
